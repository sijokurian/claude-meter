{
  "manifest_version": 3,
  "name": "Claude Meter",
  "version": "1.0.0",
  "description": "Sends Claude.ai usage data to the Claude Meter tray app",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://claude.ai/*",
    "http://localhost:52413/*",
    "http://127.0.0.1:52413/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["injector.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
